{{/*
Create a useful title from a list of scenarios.
Expects a list of scenario objects with .run_summary.scenario_name fields.
Deduplicates scenario names, truncates to three, and indicates if there are more.
*/}}
{{ $deduped_summaries := coll.Uniq (coll.JQ "map(.run_summary.scenario_name)" .) }}
{{- if gt (len $deduped_summaries) 3 -}}
{{- conv.Join (coll.GoSlice $deduped_summaries 0 3) ", " }} and {{ sub (len $deduped_summaries) 3 }} more
{{- else -}}
{{- conv.Join $deduped_summaries ", " -}}
{{- end -}}

{{/*
Render aggregate rate statistics across partitions.
Corresponding Rust type: `PartitionedRateStats`
Fields: `mean`, `max_mean`, `min_mean`, `trend`, `window_duration`

`mean` is null when no data was collected (empty frame),
in which case "N/A" is displayed.

The trend shows the mean count per time window averaged across partitions.
*/}}
{{ if ne (index . "mean") nil }}
    {{ template "scenario_metric_content_item" (dict
        "name" "Mean"
        "content" (tmpl.Exec "mean" (dict "mean" .mean "unit" "/s"))
    ) }}
    {{ template "scenario_metric_content_item" (dict
        "name" "Max"
        "description" "Highest per-partition mean rate"
        "content" (tmpl.Exec "scalar" (dict "label" "max " "value" .max_mean "unit" "/s"))
    ) }}
    {{ template "scenario_metric_content_item" (dict
        "name" "Min"
        "description" "Lowest per-partition mean rate"
        "content" (tmpl.Exec "scalar" (dict "label" "min " "value" .min_mean "unit" "/s"))
    ) }}
    {{ template "trend_graph" (dict
        "data" .trend
        "mean" .mean
        "window_duration" .window_duration
    ) }}
{{ else }}
    {{ template "scenario_metric_content_item" (dict
        "name" "Mean"
        "content" "<span class=\"no-data\">N/A</span>"
    ) }}
{{ end }}

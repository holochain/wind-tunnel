{{/*
Render counter stats: total count, rate distribution, and rate trend.
Fields (from CounterStats):

* `count` (scalar): Total increment over the measurement period.
* `measurement_duration`: A duration object with `secs` and `nanos` fields.
* `mean_rate_per_second` (scalar): Mean instantaneous rate per second.
* `std_rate_per_second` (scalar): Standard deviation of instantaneous rate.
* `p5_rate_per_second` (scalar): 5th percentile rate per second.
* `p95_rate_per_second` (scalar): 95th percentile rate per second.
* `peak_rate_per_second` (scalar): Peak instantaneous rate per second.
* `rate_trend`: Object with `trend` (array of floats) and `window_duration` (string).
* `unit` (string, optional): The unit of measurement (added by caller).

Corresponding Rust type: `holochain_summariser::model::CounterStats` with the `unit` field added on.
*/}}
<div class="delta">
    <span class="delta-count">
        {{- template "scalar" (dict "label" "total" "value" .count "unit" (index . "unit")) -}}
        <span class="delta-measurement-duration">over {{ math.Add .measurement_duration.secs (math.Div .measurement_duration.nanos 1000000000) }}s</span>
    </span>

    {{ if .mean_rate_per_second }}
        <span class="delta-rate">
            {{ template "scalar" (dict "label" "mean rate" "value" .mean_rate_per_second "unit" (print (default "" (index . "unit")) "/s")) }}
            {{ template "scalar" (dict "label" "std" "value" .std_rate_per_second "unit" (print (default "" (index . "unit")) "/s")) }}
        </span>
        <span class="delta-rate-range">
            {{ template "scalar" (dict "label" "p5" "value" .p5_rate_per_second "unit" (print (default "" (index . "unit")) "/s")) }}
            {{ template "scalar" (dict "label" "p95" "value" .p95_rate_per_second "unit" (print (default "" (index . "unit")) "/s")) }}
            {{ template "scalar" (dict "label" "peak" "value" .peak_rate_per_second "unit" (print (default "" (index . "unit")) "/s")) }}
        </span>
    {{ end }}
</div>
{{ with .rate_trend }}
    {{ template "trend_graph" (dict "data" .trend "mean" 0 "window_duration" .window_duration) }}
{{ end }}
